# agent-suite system config — PLACEHOLDERS ONLY. Copy to the system path
# (/etc/agent-suite/suite.env or %ProgramData%\agent-suite\suite.env) and fill in.
# Secrets are backend refs, never literals: vault: / akv: / wincred: / file:
#
# The per-user overlay (~/.config/agent-suite/suite.env) holds each human's
# principal_id and default project. The system file holds shared facts.

# --- Spine (regista) ---
REGISTA_DSN=postgresql://DB-SERVICE-ACCOUNT@suite-db.example:5432/regista
REGISTA_KEY_PATH=vault:secret/agent-suite/regista#signing_key
REGISTA_REQUIRE_SSL=true

# --- agent-notes native DB ---
# agent-notes uses its own database (separate from the regista store) for
# memories, links, and the op_log. If this is the same Postgres instance,
# create a dedicated database + role for agent-notes. If unset, agent-notes
# falls back to REGISTA_DSN from this file.
AGENT_NOTES_DSN=postgresql://DB-SERVICE-ACCOUNT-2@suite-db.example:5432/agent_notes
AGENT_NOTES_REGISTA_WRITES=1

# --- cairn (provenance) ---
CAIRN_PROJECT=agent_provenance

# --- Principal identity ---
# Set in the PER-USER overlay, not the system file. Each human/agent gets
# their own principal_id. The bootstrap provisions the Ed25519 keypair.
# PRINCIPAL_ID=your-principal-id

# --- Per-consumer project slugs (set in per-user overlay) ---
# AGENT_NOTES_PROJECT=project-slug
# DOSSIER_PROJECTS=project-slug,another-slug

# --- Shared-service endpoints (Plan 004 WI-1.6) ---
# Dossier deploys centrally as the team URL; the doctor checks it by endpoint
# instead of requiring a local install. When set, doctor reports
# "remote: ok @ <version>" for dossier; when unset, "not configured (shared
# service)" — a named state distinct from failure.
# DOSSIER_URL=https://dossier.work-domain.example

# --- Memory provider (Plan 012 WI-1.1) ---
# agent-notes supports a pluggable memory engine. The default is "native"
# (no external dependency). Set AGENT_NOTES_MEMORY_ENGINE=hindsight to use
# the Hindsight learned-context engine; HINDSIGHT_URL must be set when
# the engine is hindsight. The doctor checks hindsight reachability and
# makes suite_ok False on outage — no silent fallback to native.
# AGENT_NOTES_MEMORY_ENGINE=hindsight
# HINDSIGHT_URL=https://hindsight-api.work-domain.example
# HINDSIGHT_TENANT=default

# --- Entra (Azure AD) step-up authentication (Plan 014 WI-3.3) ---
# Optional: enables Entra JWT token validation for dual control.
# When configured, the EntraTokenValidator fetches JWKS keys automatically.
# ENTRA_TENANT_ID=tenant-id-placeholder
# ENTRA_CLIENT_ID=client-id-placeholder
# ENTRA_AUDIENCE=api://agent-suite
