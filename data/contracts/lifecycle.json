{
  "contract": "lifecycle",
  "version": "1.0.0",
  "description": "The canonical agentic lifecycle — states, transitions, roles, review gates, terminality, and deferral. Owned by regista; consumed by agent-notes, dossier, and agent-suite. Both faces register the exact same workflow bytes from regista.canonical_workflow_yaml().",
  "owned_by": "regista",
  "consumers": ["agent-notes", "dossier", "agent-suite"],
  "workflow_name": "canonical",
  "workflow_version": 2,
  "states": ["open", "in_progress", "blocked", "deferred", "in_review", "in_human_review", "done"],
  "initial_state": "open",
  "terminal_states": ["done"],
  "roles": ["human", "agent", "system"],
  "review_gates": ["adversarial_review", "human_gate"],
  "work_item_types": ["breadcrumb", "bug", "task"],
  "transitions": [
    {"name": "start", "from": "open", "to": "in_progress", "allowed_roles": ["human", "agent", "system"]},
    {"name": "start", "from": "deferred", "to": "in_progress", "allowed_roles": ["human", "agent", "system"]},
    {"name": "block", "from": "in_progress", "to": "blocked", "allowed_roles": ["human", "agent", "system"]},
    {"name": "unblock", "from": "blocked", "to": "in_progress", "allowed_roles": ["human", "agent", "system"]},
    {"name": "defer", "from": "open", "to": "deferred", "allowed_roles": ["human", "agent", "system"]},
    {"name": "defer", "from": "in_progress", "to": "deferred", "allowed_roles": ["human", "agent", "system"]},
    {"name": "resume", "from": "deferred", "to": "open", "allowed_roles": ["human", "agent", "system"]},
    {"name": "submit_for_review", "from": "in_progress", "to": "in_review", "allowed_roles": ["human", "agent", "system"]},
    {"name": "adversarial_pass", "from": "in_review", "to": "in_human_review", "allowed_roles": ["human", "agent", "system"], "validator": "adversarial_review"},
    {"name": "request_changes", "from": "in_review", "to": "in_progress", "allowed_roles": ["human", "agent", "system"], "validator": "adversarial_review"},
    {"name": "accept", "from": "in_human_review", "to": "done", "allowed_roles": ["human", "agent", "system"], "validator": "human_gate"},
    {"name": "reject", "from": "in_human_review", "to": "in_progress", "allowed_roles": ["human", "agent", "system"], "validator": "human_gate"},
    {"name": "reopen", "from": "done", "to": "open", "allowed_roles": ["human", "agent", "system"]},
    {"name": "close_from_open", "from": "open", "to": "done", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "open", "to": "open", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "in_progress", "to": "in_progress", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "blocked", "to": "blocked", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "deferred", "to": "deferred", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "in_review", "to": "in_review", "allowed_roles": ["human", "agent", "system"]},
    {"name": "amend", "from": "in_human_review", "to": "in_human_review", "allowed_roles": ["human", "agent", "system"]}
  ],
  "invariants": [
    "done is terminal and reachable ONLY through the two-stage review (adversarial_review + human_gate), except close_from_open (pre-work dismissal)",
    "adversarial_review requires the reviewer to differ from every author (cross-lineage)",
    "human_gate has a relaxed default (require_human: false) — any actor may accept after independent cross-lineage pass; the validator enforces a distinct accepter",
    "deferred is a first-class non-terminal idle state (deliberate park, no dependency), distinct from blocked (external dependency)",
    "Lease is NOT a lifecycle state: claim/heartbeat/release go to regista's native claims primitive (orthogonal to workflow state)",
    "done (terminal) cannot be amended directly — reopen first"
  ]
}
